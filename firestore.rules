// firestore.rules
//
// MODELO DE REGRAS DE SEGURANÇA DO FIRESTORE
// -------------------------------------------
// Atualizado para as coleções REAIS encontradas no código do site:
//   usuarios, corridas, inscricoes, pedidos, coletas, acessos,
//   financeiro/caixa (documento), playoffs/temporadaAtual (documento)
//
// Estas regras são a ÚNICA proteção que não pode ser contornada por
// alguém chamando a API do Firestore direto (DevTools, curl, app
// próprio) — diferente de validações em JavaScript no site, que só
// protegem usuários "bem comportados".
//
// IMPORTANTE — sobre o problema do "equipe.html / blacklist.html só
// mostra logado": essas duas páginas leem a coleção `usuarios`
// filtrando por `visivel == true`, e o JavaScript NÃO faz nenhuma
// checagem de login antes disso. Se está exigindo login mesmo assim,
// é porque a regra publicada hoje no seu Firebase para `usuarios`
// pede `request.auth != null`. A regra abaixo corrige isso: permite
// leitura pública apenas dos documentos com `visivel == true`
// (exatamente o que essas páginas já filtram); o resto de cada
// usuário continua protegido pelas outras regras desse mesmo bloco.
//
// Publique isto em: Firebase Console > Firestore Database > Regras,
// ou via `firebase deploy --only firestore:rules`.
// Revise nomes de campo (visivel, ordem, rank, role) contra o que
// você realmente usa — inferi pelos nomes vistos no JavaScript.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogado() {
      return request.auth != null;
    }

    function ehAdmin() {
      return estaLogado() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == "admin";
    }

    // PERFIS / PILOTOS (equipe.html, blacklist.html, piloto.html lêem
    // daqui). Leitura pública SOMENTE de quem está marcado como
    // visivel == true — é exatamente o filtro que o site já usa.
    // Edição exige estar logado como o próprio usuário, e mudar a
    // própria "role" (admin) é bloqueado.
    match /usuarios/{uid} {
      allow read: if resource.data.visivel == true || estaLogado();

      allow update: if estaLogado() && request.auth.uid == uid &&
        !("role" in request.resource.data.diff(resource.data).affectedKeys());

      allow create, delete: if ehAdmin();
    }

    // CORRIDAS / RESULTADOS — exibido publicamente em corridas.html,
    // campeonatos.html, piloto.html. Só admin cria/edita.
    match /corridas/{id} {
      allow read: if true;
      allow write: if ehAdmin();
    }

    // INSCRIÇÕES (formulario.html) — única coleção com escrita
    // pública, e validada campo a campo.
    match /inscricoes/{id} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly(["tabletNome", "carro", "status", "criadoEm"]) &&
        request.resource.data.tabletNome is string &&
        request.resource.data.tabletNome.size() > 0 &&
        request.resource.data.tabletNome.size() <= 40 &&
        request.resource.data.carro is string &&
        request.resource.data.carro.size() > 0 &&
        request.resource.data.carro.size() <= 40 &&
        request.resource.data.status == "pendente";

      allow update, delete: if ehAdmin();
    }

    // PEDIDOS, COLETAS — informação interna (vendas/comissões),
    // exige login. Troque para ehAdmin() se só admin deve ver tudo.
    match /pedidos/{id} {
      allow read, write: if estaLogado();
    }

    match /coletas/{id} {
      allow read, write: if estaLogado();
    }

    // FINANCEIRO / CAIXA — sensível, só admin.
    match /financeiro/{id} {
      allow read, write: if ehAdmin();
    }

    // PLAYOFFS — leitura pública (mostrado no site), escrita só admin.
    match /playoffs/{id} {
      allow read: if true;
      allow write: if ehAdmin();
    }

    // ACESSOS (log de quem acessou o quê) — só admin lê; qualquer
    // visitante pode gerar um registro (se o próprio site grava isso
    // automaticamente); nada pode ser alterado/apagado depois.
    match /acessos/{id} {
      allow read: if ehAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // Bloqueia qualquer coleção não listada explicitamente acima.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
